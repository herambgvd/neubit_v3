# This repo is BUILT and RUN inside Linux containers. Every text file must keep LF
# line endings in the working tree — even when checked out on Windows — otherwise
# shell scripts + configs mounted into containers break (a CRLF shebang → the shell
# can't find the interpreter → the container exits 127). This overrides a Windows
# core.autocrlf=true, which would otherwise rewrite LF→CRLF on checkout.
* text=auto eol=lf

# Binaries — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.mp4   binary
*.webm  binary
*.wasm  binary
*.gz    binary
*.zip   binary
*.tar   binary
*.jar   binary
*.so    binary
