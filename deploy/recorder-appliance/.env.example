# ─────────────────────────────────────────────────────────────────────
# Neubit v3 — STANDALONE RECORDER APPLIANCE config.
# Copy to `.env` (same folder) and edit before `docker compose up -d`.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# ── First-login admin ────────────────────────────────────────────────
# The bootstrap operator account, created ONCE on first boot into the embedded
# SQLite estate. If VE_NODE_ADMIN_PASSWORD is left BLANK the node generates a
# strong random password and prints it once to the container logs
# (docker compose logs nvr | grep "bootstrap admin password").
VE_NODE_ADMIN_USER=admin
VE_NODE_ADMIN_PASSWORD=change-me-strong-password

# ── Node identity + crypto ───────────────────────────────────────────
# Human-readable name for this recorder (shown in the UI / future enrollment).
VE_NODE_NAME=recorder-01

# Node enrollment secret. Blank → generated once + printed to the logs. Only needed
# if you later enroll this box into a central controller; standalone can leave blank.
VE_NODE_SECRET=

# HMAC anchor for login JWTs AND the media tokens that gate live/playback. Set a
# long random value (e.g. `openssl rand -hex 32`) and KEEP IT STABLE — changing it
# invalidates existing sessions + in-flight media URLs. Do NOT ship the default.
VE_JWT_SECRET=change-me-openssl-rand-hex-32

# ── Media reachability ───────────────────────────────────────────────
# The address a LAN browser uses to reach THIS recorder for video (its hostname or
# LAN IP). Live HLS/WHEP + recorded playback URLs are built from it. `localhost`
# only works when browsing from the recorder itself; set the box's LAN IP/hostname
# (e.g. 192.168.1.50 or recorder-01.local) to view from other machines.
VE_MEDIA_ADVERTISE_HOST=localhost

# ── Exposed host ports ───────────────────────────────────────────────
# UI + node API (open http://<recorder-host>:<this>).
VE_UI_PORT=8080
# MediaMTX browser-facing media surfaces.
VE_RTSP_PORT=8554         # RTSP (device/tool ingest + pull)
VE_HLS_PORT=8888          # HLS live
VE_WHEP_PORT=8889         # WebRTC/WHEP live signaling
VE_PLAYBACK_PORT=9996     # recorded fmp4 playback
VE_WEBRTC_ICE_PORT=8189   # WebRTC ICE (UDP+TCP)

# ── Recording tunables (optional) ────────────────────────────────────
VE_RECORD_SEGMENT_DURATION=60s   # length of each fmp4 recording segment
VE_RECORD_TICK_SEC=15            # recording reconcile + segment-scan interval
VE_MEDIA_NODE_ID=mediamtx-0      # this node's media-node id (rarely changed)

# ── Federation (leave off for a standalone box) ──────────────────────
FEDERATION_ENABLED=false
