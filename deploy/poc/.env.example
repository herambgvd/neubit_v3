# ─────────────────────────────────────────────────────────────────────────────
# Neubit v3 — POC deployment env (single Windows Server, accessed by IP).
#
# HOW TO USE:
#   1. Copy this file to  deploy/.env
#   2. Replace every  __SERVER_IP__  with this machine's LAN IP (e.g. 192.162.0.11).
#      PowerShell one-liner (run from deploy/):
#         (Get-Content .env) -replace '__SERVER_IP__','192.162.0.11' | Set-Content .env
#   3. Change the two secrets + the admin password below.
#
# Everything is served on the server IP through the gateway on :80 —
#   Operator console : http://__SERVER_IP__/
#   Superadmin panel : http://admin.localhost/   (host-based; see README)
# ─────────────────────────────────────────────────────────────────────────────

POSTGRES_USER=neubit
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=neubit_control

VE_ENV=prod
VE_DATABASE_URL=postgresql+asyncpg://neubit:CHANGE_ME_strong_db_password@postgres:5432/neubit_control
VE_REDIS_URL=redis://redis:6379/0
VE_NATS_URL=nats://nats:4222

# ── Secrets — CHANGE BOTH to long random strings (openssl rand -hex 32) ──
VE_JWT_SECRET=CHANGE_ME_long_random_jwt_secret_min_32_bytes
VE_SECRETS_KEY=CHANGE_ME_long_random_secrets_key_min_32_bytes

# ── First-boot superadmin (login once, then rotate in the UI) ──
VE_BOOTSTRAP_ADMIN_EMAIL=support@geniusvision.in
VE_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_admin_password

# ── IP access: allow the server IP (+ admin host) as CORS origins ──
VE_CORS_ORIGINS=["http://__SERVER_IP__","http://admin.localhost"]

VE_STORAGE_BACKEND=local
VE_STORAGE_LOCAL_DIR=/app/data/storage

# ── Frontend API base ──
# EMPTY = same-origin relative (/api/v1 via the gateway) → works on the server IP with
# NO rebuild. Leave blank; do NOT set to http://localhost (that breaks IP access).
NEXT_PUBLIC_API_URL=

# ── Media public bases — MUST be the server IP so the browser (on the tower or any
#    other machine) can reach HLS/WHEP/playback through the gateway. ──
VE_MEDIA_PUBLIC_HLS_BASE=http://__SERVER_IP__/media/hls
VE_MEDIA_PUBLIC_WHEP_BASE=http://__SERVER_IP__/media/whep
VE_MEDIA_PUBLIC_PLAYBACK_BASE=http://__SERVER_IP__/media/playback
VE_MEDIAMTX_RTSP_BASE=rtsp://__SERVER_IP__:8554

# ── WebRTC ICE — advertise the server IP so the browser can reach the media UDP/TCP
#    port from another machine (the tower). Comma-separated, NO brackets. ──
MTX_WEBRTCADDITIONALHOSTS=__SERVER_IP__

# ── Recording segment interval + retention sweep (prod defaults) ──
VE_RECORDINGS_DIR=/recordings
VE_RETENTION_TICK_SEC=300
VE_DEFAULT_RETENTION_DAYS=30

# ── Ops-agent shared token — rotate for production ──
OPS_AGENT_TOKEN=CHANGE_ME_random_ops_token
OPS_AGENT_URL=http://ops-agent:9000
